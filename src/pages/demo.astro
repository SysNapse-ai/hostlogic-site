---
import BaseLayout from '../layouts/BaseLayout.astro';
import DemoShowcase from '../components/DemoShowcase.astro';
import AnfitriDemoChat from '../components/AnfitriDemoChat.astro';

// Demonstração visual com dados fictícios. Futuro: substituir/combinar com prints reais
// capturados do app e vídeo (YouTube não listado / Cloudflare Stream / R2).
---

<BaseLayout
  title="Demonstração"
  description="Demonstração visual do HostLogic: portal do hóspede, Anfitri-IA, reservas, financeiro e faxina."
>
  <div class="container page-head">
    <span class="badge">Demonstração do produto</span>
    <h1>Como o HostLogic aparece na operação do anfitrião</h1>
    <p>
      Frames com dados fictícios para apresentar os principais valores: portal do hóspede completo,
      Anfitri-IA, timeline de reservas, financeiro e faxina comprovada.
    </p>
  </div>

  <DemoShowcase />

  <section class="block" id="anfitri-ia-demo-section">
    <div class="container">
      <div class="page-head" style="margin-bottom: 0.5rem;">
        <span class="badge">Anfitri-IA ao vivo</span>
        <h2>Converse com a Anfitri-IA agora</h2>
        <p>
          Demonstração interativa: faça até 6 perguntas e veja como ela responde com base no site —
          quando não encontra na base, avisa e responde de forma ilustrativa.
        </p>
      </div>
      <AnfitriDemoChat />
    </div>
  </section>
</BaseLayout>
