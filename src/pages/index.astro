---
import BaseLayout from '../layouts/BaseLayout.astro';
import EarlyAccessForm from '../components/EarlyAccessForm.astro';
import { APP_URL } from '../consts';

// HOME DE TESTE (BRUTA). Estrutura pronta para evoluir para marketing comercial completo
// (todas as funções do sistema apresentadas comercialmente). Ver docs/SITE_FUTURE_INTEGRATIONS.md.
// Fase inicial: contato SOMENTE por e-mail e telefone — sem formulário/automação.

const features = [
  { title: 'Reservas capturadas', desc: 'Captura por iCal e e-mail coletor (Airbnb), sem digitação manual.' },
  { title: 'Calendário multi-imóvel', desc: 'Check-ins, check-outs e ocupação de todas as propriedades num só lugar.' },
  { title: 'Faxinas e equipe', desc: 'Limpeza por checkout, gestão da equipe e auditoria por fotos de itens sorteados na faxina.' },
  {
    title: 'Portal do hóspede',
    desc: 'Check-in digital com documento e selfie; titular cadastra acompanhantes ou envia link por WhatsApp para cada um.',
  },
  { title: 'Automação de cadastro', desc: 'Integração com sistemas de condomínio/portaria e automações.' },
  { title: 'Segurança e LGPD', desc: 'Multi-tenant com RLS, mascaramento de PII e retenção de dados.' },
];
---

<BaseLayout>
  <section class="hero">
    <div class="container">
      <span class="badge">Versão de teste do site</span>
      <h1>Operação de hospedagem, do jeito profissional.</h1>
      <p class="lead">
        Reservas, calendário, faxinas e um portal do hóspede que coleta dados e fotos para check-in —
        com LGPD e automações de condomínio. Esta é uma página inicial de teste; o conteúdo comercial
        completo chega em breve.
      </p>
      <div class="cta">
        <a class="btn btn-primary" href={APP_URL}>Acessar o sistema</a>
        <a class="btn btn-ghost" href="#inscreva-se">Lista de espera</a>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="container">
      <h2>O que o HostLogic faz</h2>
      <p class="sub">Resumo das áreas do sistema (apresentação comercial detalhada virá depois).</p>
      <div class="grid">
        {features.map((f) => (
          <div class="card">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="block portal-spotlight" id="portal-hospede">
    <div class="container portal-spotlight__grid">
      <div>
        <h2>Portal do hóspede — check-in digital completo</h2>
        <p class="sub">
          O hóspede titular recebe o link (mensagem automática do Airbnb ou envio seu) e conclui o
          cadastro no celular, com fotos e consentimento LGPD.
        </p>
        <ul class="portal-steps">
          <li>
            <strong>Titular da reserva</strong> preenche dados pessoais, documento com foto e selfie
            de verificação no fluxo guiado.
          </li>
          <li>
            <strong>Acompanhantes</strong> podem ser cadastrados pelo titular no mesmo link ou receber
            um <strong>convite individual</strong> — você copia o link ou envia direto pelo
            <strong>WhatsApp</strong> para cada adulto/criança com vaga na reserva.
          </li>
          <li>
            Depois do envio, o hóspede vê o <strong>guia do imóvel</strong> (regras, Wi‑Fi, acesso) e
            você acompanha o status em <strong>Reservas capturadas</strong> no painel.
          </li>
        </ul>
        <p class="portal-note">
          Bebês e vagas sem convite seguem as regras da reserva; o titular pode completar o que faltar
          no portal.
        </p>
      </div>
      <div class="portal-flow card" aria-hidden="true">
        <p class="portal-flow__label">Fluxo resumido</p>
        <ol class="portal-flow__list">
          <li>Link da reserva → portal seguro</li>
          <li>Titular: documento + selfie</li>
          <li>Acompanhantes: no portal ou link próprio</li>
          <li>Dados prontos para portaria / operação</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="block" id="demo">
    <div class="container">
      <h2>Demonstração em vídeo</h2>
      <p class="sub">Em breve: um vídeo curto mostrando a utilização do sistema na prática.</p>
      <div class="video-frame">Espaço reservado para o vídeo de demonstração (a publicar).</div>
    </div>
  </section>

  <EarlyAccessForm />
</BaseLayout>
