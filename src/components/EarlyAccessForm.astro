---
import { CONTACT, LEGAL } from '../consts';

const propertyOptions = [
  { value: '', label: 'Selecione…' },
  { value: '1', label: '1 imóvel' },
  { value: '2-5', label: '2 a 5 imóveis' },
  { value: '6-10', label: '6 a 10 imóveis' },
  { value: '11-20', label: '11 a 20 imóveis' },
  { value: '20+', label: 'Mais de 20 imóveis' },
];
---

<section class="early-access" id="inscreva-se" aria-labelledby="early-access-title">
  <div class="container early-access__inner">
    <p class="early-access__kicker">Inscreva-se</p>
    <h2 id="early-access-title" class="early-access__title">Quero acesso antecipado.</h2>
    <p class="early-access__lead">
      Seja um dos primeiros a usar o HostLogic. Preencha o formulário e entraremos em contato.
    </p>

    <form class="early-form" id="early-access-form" novalidate>
      <div class="early-form__grid">
        <div class="early-form__field">
          <label for="ea-name">Nome <span aria-hidden="true">*</span></label>
          <input
            id="ea-name"
            name="name"
            type="text"
            autocomplete="name"
            required
            placeholder="Seu nome completo"
          />
        </div>
        <div class="early-form__field">
          <label for="ea-email">E-mail <span aria-hidden="true">*</span></label>
          <input
            id="ea-email"
            name="email"
            type="email"
            autocomplete="email"
            required
            placeholder="seu@email.com"
          />
        </div>
        <div class="early-form__field early-form__field--full">
          <label for="ea-location">Localização <span class="early-form__optional">(opcional)</span></label>
          <input
            id="ea-location"
            name="location"
            type="text"
            autocomplete="address-level2"
            placeholder="Cidade, Estado, CEP"
          />
        </div>
        <div class="early-form__field early-form__field--full">
          <label for="ea-properties">Quantos imóveis você gerencia?</label>
          <select id="ea-properties" name="properties" required>
            {propertyOptions.map((opt) => (
              <option value={opt.value} disabled={opt.value === ''} selected={opt.value === ''}>
                {opt.label}
              </option>
            ))}
          </select>
        </div>
      </div>

      <label class="early-form__consent">
        <input type="checkbox" name="consent" required />
        <span>
          Autorizo o contacto da HostLogic pelo e-mail informado para falar sobre o acesso antecipado.
          Li a{' '}
          <a href={LEGAL.privacy} target="_blank" rel="noopener noreferrer">política de privacidade</a>.
        </span>
      </label>

      <button type="submit" class="early-form__submit">
        Quero acesso antecipado <span aria-hidden="true">→</span>
      </button>

      <p class="early-form__error" id="early-form-error" role="alert" hidden></p>
    </form>

    <div class="early-form__success" id="early-form-success" hidden>
      <p class="early-form__success-title">Pedido recebido</p>
      <p>
        Obrigado pelo interesse. Entraremos em contacto em breve no e-mail que indicou.
        Se preferir, escreva também para{' '}
        <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>.
      </p>
    </div>

    <p class="early-access__footnote">
      Já é cliente? <a href="https://app.hostlogic.com.br">Acessar o sistema</a>.
    </p>
  </div>
</section>

<script define:vars={{ contactEmail: CONTACT.email }}>
  const form = document.getElementById('early-access-form');
  const success = document.getElementById('early-form-success');
  const errorEl = document.getElementById('early-form-error');

  if (!form || !success || !errorEl) {
    // noop
  } else {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      errorEl.hidden = true;
      errorEl.textContent = '';

      const fd = new FormData(form);
      const name = String(fd.get('name') || '').trim();
      const email = String(fd.get('email') || '').trim();
      const location = String(fd.get('location') || '').trim();
      const properties = String(fd.get('properties') || '').trim();
      const consent = fd.get('consent');

      if (!name || !email || !properties) {
        errorEl.textContent = 'Preencha nome, e-mail e quantidade de imóveis.';
        errorEl.hidden = false;
        return;
      }
      if (!consent) {
        errorEl.textContent = 'É necessário aceitar o contacto conforme a política de privacidade.';
        errorEl.hidden = false;
        return;
      }

      const lines = [
        'Pedido de acesso antecipado — HostLogic',
        '',
        `Nome: ${name}`,
        `E-mail: ${email}`,
        location ? `Localização: ${location}` : 'Localização: (não informado)',
        `Imóveis geridos: ${properties}`,
        '',
        `Enviado em: ${new Date().toISOString()}`,
      ];
      const subject = encodeURIComponent('HostLogic — Acesso antecipado');
      const body = encodeURIComponent(lines.join('\n'));
      const mailto = `mailto:${contactEmail}?subject=${subject}&body=${body}`;

      window.location.href = mailto;
      form.hidden = true;
      success.hidden = false;
    });
  }
</script>
