---
import { CONTACT, LEGAL } from '../consts';

const propertyOptions = [
  { value: '', label: 'Selecione…' },
  { value: '1', label: '1 imóvel' },
  { value: '2-5', label: '2 a 5 imóveis' },
  { value: '6-10', label: '6 a 10 imóveis' },
  { value: '11-20', label: '11 a 20 imóveis' },
  { value: '20+', label: 'Mais de 20 imóveis' },
];

const waitlistPoints = [
  'Anfitri-IA no portal (hóspede) e no painel de gestão, treinada por imóvel',
  'Portal do hóspede com check-in digital, fotos e convite de acompanhantes por WhatsApp',
  'Prioridade no onboarding com a equipe HostLogic',
  'Sem compromisso — só pedimos os dados para contato',
];
---

<section class="early-access" id="inscreva-se" aria-labelledby="early-access-title">
  <div class="container early-access__shell">
    <div class="early-access__intro">
      <span class="early-access__badge">Lista de espera</span>
      <h2 id="early-access-title" class="early-access__title">
        Entre na fila de <span class="early-access__accent">acesso antecipado</span>
      </h2>
      <p class="early-access__lead">
        Estamos abrindo vagas para anfitriões que querem reservas, faxinas e check-in digital dos
        hóspedes (titular + acompanhantes) num só painel. Deixe seus dados e respondemos por e-mail.
      </p>
      <ul class="early-access__list">
        {waitlistPoints.map((point) => (
          <li>{point}</li>
        ))}
      </ul>
    </div>

    <div class="early-access__panel">
      <p class="early-form__panel-title">Cadastro rápido</p>
      <p class="early-form__panel-sub">
        Leva menos de 1 minuto. Ao enviar, copie a mensagem ou abra seu e-mail — o site ainda não
        dispara e-mail automaticamente.
      </p>

      <form class="early-form" id="early-access-form" novalidate>
        <div class="early-form__stack">
          <div class="early-form__field">
            <label for="ea-name">Nome completo</label>
            <input
              id="ea-name"
              name="name"
              type="text"
              autocomplete="name"
              required
              placeholder="Como devemos te chamar?"
            />
          </div>
          <div class="early-form__field">
            <label for="ea-email">E-mail profissional</label>
            <input
              id="ea-email"
              name="email"
              type="email"
              autocomplete="email"
              required
              placeholder="voce@empresa.com.br"
            />
          </div>
          <div class="early-form__field">
            <label for="ea-location">
              Cidade ou região <span class="early-form__optional">opcional</span>
            </label>
            <input
              id="ea-location"
              name="location"
              type="text"
              autocomplete="address-level2"
              placeholder="Ex.: Curitiba, PR"
            />
          </div>
          <div class="early-form__field">
            <label for="ea-properties">Portfólio de imóveis</label>
            <select id="ea-properties" name="properties" required>
              {propertyOptions.map((opt) => (
                <option value={opt.value} disabled={opt.value === ''} selected={opt.value === ''}>
                  {opt.label}
                </option>
              ))}
            </select>
          </div>
        </div>

        <label class="early-form__consent">
          <input type="checkbox" name="consent" required />
          <span>
            Aceito ser contatado pela HostLogic sobre o programa de acesso antecipado e li a{' '}
            <a href={LEGAL.privacy} target="_blank" rel="noopener noreferrer">política de privacidade</a>.
          </span>
        </label>

        <button type="submit" class="early-form__submit">Enviar interesse</button>

        <p class="early-form__error" id="early-form-error" role="alert" hidden></p>
      </form>

      <div class="early-form__success" id="early-form-success" hidden>
        <p class="early-form__success-title">Quase lá — avise a equipe HostLogic</p>
        <p class="early-form__success-lead">
          Seus dados foram validados. Para entrar na lista de espera, envie a mensagem abaixo para{' '}
          <span class="early-form__email-inline">{CONTACT.email}</span> (copiar ou abrir o e-mail).
        </p>
        <pre class="early-form__preview" id="early-form-preview" aria-label="Texto do pedido"></pre>
        <div class="early-form__success-actions">
          <button type="button" class="early-form__submit" id="early-form-copy">
            Copiar mensagem
          </button>
          <button type="button" class="early-form__mailto-btn" id="early-form-mailto">
            Abrir no meu e-mail
          </button>
        </div>
        <p class="early-form__success-hint" id="early-form-copy-feedback" role="status" hidden></p>
        <p class="early-form__success-hint">
          Se o Windows pedir um aplicativo de e-mail, escolha Outlook, Gmail ou outro — ou use só
          «Copiar mensagem» e cole manualmente.
        </p>
      </div>

      <p class="early-access__footnote">
        Já utiliza o painel? <a href="https://app.hostlogic.com.br">Ir para o login</a>
      </p>
    </div>
  </div>
</section>

<script define:vars={{ contactEmail: CONTACT.email }}>
  const form = document.getElementById('early-access-form');
  const success = document.getElementById('early-form-success');
  const errorEl = document.getElementById('early-form-error');
  const previewEl = document.getElementById('early-form-preview');
  const copyBtn = document.getElementById('early-form-copy');
  const mailtoBtn = document.getElementById('early-form-mailto');
  const copyFeedback = document.getElementById('early-form-copy-feedback');

  let pendingMailto = '';

  function buildLeadMessage(name, email, location, properties) {
    return [
      'Lista de espera — HostLogic',
      '',
      `Nome: ${name}`,
      `E-mail: ${email}`,
      location ? `Localização: ${location}` : 'Localização: (não informado)',
      `Imóveis geridos: ${properties}`,
      '',
      `Enviado em: ${new Date().toISOString()}`,
    ].join('\n');
  }

  if (form && success && errorEl && previewEl && copyBtn && mailtoBtn) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      errorEl.hidden = true;
      errorEl.textContent = '';
      if (copyFeedback) {
        copyFeedback.hidden = true;
        copyFeedback.textContent = '';
      }

      const fd = new FormData(form);
      const name = String(fd.get('name') || '').trim();
      const email = String(fd.get('email') || '').trim();
      const location = String(fd.get('location') || '').trim();
      const properties = String(fd.get('properties') || '').trim();
      const consent = fd.get('consent');

      if (!name || !email || !properties) {
        errorEl.textContent = 'Preencha nome, e-mail e portfólio de imóveis.';
        errorEl.hidden = false;
        return;
      }
      if (!consent) {
        errorEl.textContent = 'Marque o consentimento para continuar.';
        errorEl.hidden = false;
        return;
      }

      const plainBody = buildLeadMessage(name, email, location, properties);
      previewEl.textContent = plainBody;
      const subject = encodeURIComponent('HostLogic — Lista de espera');
      const body = encodeURIComponent(plainBody);
      pendingMailto = `mailto:${contactEmail}?subject=${subject}&body=${body}`;

      form.hidden = true;
      success.hidden = false;
    });

    copyBtn.addEventListener('click', async () => {
      const text = previewEl.textContent || '';
      try {
        await navigator.clipboard.writeText(
          `Para: ${contactEmail}\nAssunto: HostLogic — Lista de espera\n\n${text}`,
        );
        if (copyFeedback) {
          copyFeedback.textContent = 'Mensagem copiada. Cole no seu e-mail e envie.';
          copyFeedback.hidden = false;
        }
      } catch {
        if (copyFeedback) {
          copyFeedback.textContent =
            'Não foi possível copiar automaticamente. Selecione o texto acima e copie (Ctrl+C).';
          copyFeedback.hidden = false;
        }
      }
    });

    mailtoBtn.addEventListener('click', () => {
      if (pendingMailto) window.location.href = pendingMailto;
    });
  }
</script>
