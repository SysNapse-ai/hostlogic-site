{
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2022",
    "lib": ["es2022"],
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts", "../src/data/features.ts", "../src/consts.ts"],
  "exclude": ["dist", "node_modules"]
}
